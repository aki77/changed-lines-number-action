{
  "name": "changed-lines-number-action",
  "version": "4.0.0",
  "private": true,
  "description": "Add the number of changed lines to the PR body, considering `.gitattributes`.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "package": "rimraf ./dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest",
    "all": "pnpm run lint && pnpm run test && pnpm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aki77/changed-lines-number-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "markdown-table": "^3.0.4",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/picomatch": "^4.0.0",
    "jest": "^30.2.0",
    "js-yaml": "^4.1.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.62.0",
    "ts-jest": "^29.4.11",
    "ts-jest-resolver": "^2.0.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
